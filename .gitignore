# ===========================================
# FastAPI React Todo - Git 忽略配置
# ===========================================
# 教学提示: .gitignore 用于指定不应被 Git 跟踪的文件
# 这可以防止敏感信息、依赖文件等被提交到仓库
# ===========================================

# -----------------
# 日志文件
# -----------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------
# 前端构建输出
# -----------------
node_modules/          # Node.js 依赖目录
dist/                  # 构建输出目录
dist-ssr/              # SSR 构建输出
*.local                # 本地配置文件

# -----------------
# 编辑器和 IDE
# -----------------
.vscode/*
!.vscode/extensions.json  # 保留推荐的扩展配置
!.vscode/settings.json     # 保留工作区设置
!.vscode/launch.json       # 保留调试配置
.idea/                     # JetBrains IDE
.DS_Store                  # macOS 系统文件
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------
# Python 后端
# -----------------
.venv/                 # Python 虚拟环境
venv/
__pycache__/           # Python 字节码缓存
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
.env                   # 环境变量文件（可能包含敏感信息）
.env.local
.env.*.local

# -----------------
# 数据库文件
# -----------------
*.db                   # SQLite 数据库文件
*.db-journal           # SQLite 日志文件
*.sqlite
*.sqlite3

# -----------------
# 测试覆盖率
# -----------------
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# -----------------
# 其他
# -----------------
*.bak                  # 备份文件
*.tmp
*.temp
.secrets               # 敏感信息文件