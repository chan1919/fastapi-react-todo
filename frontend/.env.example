# ===========================================
# FastAPI React Todo - 前端环境变量配置示例
# ===========================================
# 教学提示：
# 1. 复制此文件为 .env.local 进行本地开发配置
# 2. 不要将包含敏感信息的 .env 文件提交到版本控制
# 3. Vite 只暴露以 VITE_ 开头的环境变量
# ===========================================

# API 基础 URL
# 开发环境通常不需要设置，默认使用 http://localhost:8000
# 生产环境设置为实际的后端 API 地址
# 示例：VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# 应用标题（可选）
VITE_APP_TITLE=Todo 待办事项