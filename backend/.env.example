# ===========================================
# FastAPI React Todo - 后端环境变量配置示例
# ===========================================
# 教学提示：
# 1. 复制此文件为 .env 进行本地开发配置
# 2. 不要将包含敏感信息的 .env 文件提交到版本控制
# 3. 生产环境应使用安全的配置管理方式
# ===========================================

# 运行环境
# 可选值：development, production
ENVIRONMENT=development

# 服务器端口
PORT=8000

# 数据库配置
# SQLite 数据库文件路径（可选，默认使用应用目录下的 todos.db）
# DATABASE_PATH=/path/to/your/database.db

# SQL 日志开关
# 可选值：true, false
# 生产环境建议设置为 false
ECHO_SQL=true

# CORS 允许的源（逗号分隔）
# 生产环境应设置具体的域名
# CORS_ORIGINS=https://example.com,https://www.example.com